{
  "expo": {
    "name": "Spark HRMS",
    "slug": "SparkHR-MobileApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/LogoIcon.png",
    "scheme": "sparkhrmobileapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/LogoIcon.png",
      "bundleIdentifier": "com.yash.daksh.SparkHRMobileApp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/LogoIcon.png",
        "backgroundImage": "./assets/images/LogoIcon.png",
        "monochromeImage": "./assets/images/LogoIcon.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.yash.daksh.SparkHRMobileApp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/screen.svg"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/LogoIcon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow SparkHR to use your location to verify attendance.",
          "locationWhenInUsePermission": "Allow SparkHR to use your location to verify attendance."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow SparkHR to access your camera for attendance selfie."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow SparkHR to access your camera for attendance selfie."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f92ef03d-4f71-47ab-ad40-ec6e95fdec09"
      }
    }
  }
}
